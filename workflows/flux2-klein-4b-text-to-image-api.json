      "noise": ["15", 0],
      "guider": ["14", 0],
      "sampler": ["16", 0],
      "sigmas": ["8", 0],
      "latent_image": ["7", 0]
    }
  },
  "18": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["17", 0],
      "vae": ["4", 0]
    }
  },
  "19": {
    "class_type": "SaveImage",
    "inputs": {
